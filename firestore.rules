rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isGroupMember(groupId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
    }

    function isGroupAdmin(groupId) {
      return isSignedIn() &&
        request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.adminId;
    }

    // ─── Users ───
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Never delete users
    }

    // ─── Groups ───
    match /groups/{groupId} {
      // Any signed-in user can read groups (needed for invite-code join lookup)
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Members and admins can update; OR a signed-in user can join (add only
      // themselves to memberIds/payoutOrder and nothing else)
      allow update: if isGroupMember(groupId)
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['memberIds', 'payoutOrder'])
            && request.auth.uid in request.resource.data.memberIds
            && !(request.auth.uid in resource.data.memberIds));
      allow delete: if isGroupAdmin(groupId);
    }

    // ─── Contributions ───
    match /contributions/{contributionId} {
      // Owner can always read their own contributions (enables memberId-filtered queries).
      // Group members can also read all contributions for their group.
      allow read: if isOwner(resource.data.memberId) || isGroupMember(resource.data.groupId);
      allow create: if isGroupAdmin(request.resource.data.groupId);
      allow update: if isGroupAdmin(resource.data.groupId);
      allow delete: if isGroupAdmin(resource.data.groupId);
    }

    // ─── Loans ───
    match /loans/{loanId} {
      allow read: if isOwner(resource.data.borrowerId) || isGroupMember(resource.data.groupId);
      allow create: if isGroupMember(request.resource.data.groupId) &&
        request.auth.uid == request.resource.data.borrowerId;
      allow update: if isGroupAdmin(resource.data.groupId) ||
        (isOwner(resource.data.borrowerId) &&
          // Members can only update their own loan repayment amount
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['amountRepaid', 'status']));
      allow delete: if false;
    }

    // ─── Payouts ───
    match /payouts/{payoutId} {
      allow read: if isGroupMember(resource.data.groupId);
      allow create: if isGroupAdmin(request.resource.data.groupId);
      allow update: if isGroupAdmin(resource.data.groupId);
      allow delete: if false;
    }

    // ─── Fines ───
    match /fines/{fineId} {
      allow read: if isGroupMember(resource.data.groupId);
      allow create: if isGroupAdmin(request.resource.data.groupId);
      allow update: if isGroupAdmin(resource.data.groupId);
      allow delete: if isGroupAdmin(resource.data.groupId);
    }

    // ─── Notifications ───
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // ─── Invitations ───
    match /invitations/{inviteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ─── Contribution Requests ───
    match /contributionRequests/{reqId} {
      // Member can read their own; admin can read all for their group
      allow read: if isSignedIn() && (
        isOwner(resource.data.memberId) ||
        isGroupAdmin(resource.data.groupId)
      );
      // Any signed-in member can create a request for themselves
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.memberId;
      // Only admin can approve/reject (update status)
      allow update: if isGroupAdmin(resource.data.groupId);
      allow delete: if false;
    }

    // ─── Repayment Requests ───
    match /repaymentRequests/{reqId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.memberId) ||
        isGroupAdmin(resource.data.groupId)
      );
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.memberId;
      allow update: if isGroupAdmin(resource.data.groupId);
      allow delete: if false;
    }

    // ─── Fine Payment Requests ───
    match /finePaymentRequests/{reqId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.memberId) ||
        isGroupAdmin(resource.data.groupId)
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.memberId;
      allow update: if isGroupAdmin(resource.data.groupId);
      allow delete: if false;
    }

    // ─── Group Broadcasts ───
    match /groupBroadcasts/{broadcastId} {
      // Group members can read broadcasts for their group
      allow read: if isGroupMember(resource.data.groupId);
      // Only admin can create a broadcast
      allow create: if isGroupAdmin(request.resource.data.groupId);
      // Any signed-in member can update reactions field only; admin can update anything
      allow update: if isGroupAdmin(resource.data.groupId) ||
        (isGroupMember(resource.data.groupId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']));
      allow delete: if isGroupAdmin(resource.data.groupId);
    }

    // ─── Join Requests ───
    match /joinRequests/{requestId} {
      // Requester can read their own; group admin can read all for their group
      allow read: if isSignedIn() && (
        isOwner(resource.data.userId) ||
        isGroupAdmin(resource.data.groupId)
      );
      // Any authenticated user can create a request for themselves
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.userId &&
        request.resource.data.status == 'pending';
      // Only the group admin can approve or reject
      allow update: if isGroupAdmin(resource.data.groupId);
      allow delete: if isGroupAdmin(resource.data.groupId);
    }
  }
}
