// INSTRUCTIONS — read carefully before filling in
// ─────────────────────────────────────────────────────────────────────────────
// 1. Go to Firebase Console → Project Settings → Service Accounts tab
// 2. Click "Generate new private key" → download the JSON file
// 3. Copy this file to:  lib/core/constants/fcm_service_account.dart
//    (the real file is git-ignored — never commit it)
// 4. Fill in the three values below from the downloaded JSON
// ─────────────────────────────────────────────────────────────────────────────

// ignore_for_file: constant_identifier_names

class FcmServiceAccount {
  /// Value of "client_email" from the downloaded service-account JSON
  static const String clientEmail = 'YOUR_SERVICE_ACCOUNT_EMAIL@ikimina-digitalized.iam.gserviceaccount.com';

  /// Value of "private_key" from the downloaded service-account JSON
  /// Paste the entire multi-line string — keep the \n characters as-is
  static const String privateKey = '''-----BEGIN RSA PRIVATE KEY-----
PASTE_YOUR_PRIVATE_KEY_HERE
-----END RSA PRIVATE KEY-----''';

  /// Your Firebase project ID (already known — do not change)
  static const String projectId = 'ikimina-digitalized';
}
